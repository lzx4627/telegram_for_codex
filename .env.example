# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remote_coding_agent

# Telegram
TELEGRAM_BOT_TOKEN=<from @BotFather>
TELEGRAM_STREAMING_MODE=stream  # stream (default) | batch
MAX_CONCURRENT_CONVERSATIONS=10
PORT=3000

# Codex
# Preferred on host machines: run `codex login`
# Optional env-based auth (values can be copied from ~/.codex/auth.json)
# On Linux/Mac: cat ~/.codex/auth.json
# On Windows: type %USERPROFILE%\.codex\auth.json
OPENAI_API_KEY=
CODEX_ID_TOKEN=eyJ...
CODEX_ACCESS_TOKEN=eyJ...
CODEX_REFRESH_TOKEN=rt_...
CODEX_ACCOUNT_ID=6a6a7ba6-...

# Optional GitHub Token (used only by legacy GitHub/clone flows)
GH_TOKEN=ghp_...
GITHUB_TOKEN=ghp_...

# Optional GitHub Webhooks
WEBHOOK_SECRET=your_random_secret_string

# Legacy GitHub streaming mode
GITHUB_STREAMING_MODE=batch     # batch (default) | stream

# Optional legacy workspace path
WORKSPACE_PATH=./workspace
